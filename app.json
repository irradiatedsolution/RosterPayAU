{
  "expo": {
    "name": "RosterPayAU",
    "slug": "rosterpay-au",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4D9FD6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.rosterpay.app",
      "icon": "./assets/icon.png"
    },
    "scheme": "rosterpay",
    "plugins": [
      "expo-router"
    ],
    "android": {
      "package": "au.rosterpay.app"
    }
  }
}
